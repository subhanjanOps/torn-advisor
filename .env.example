# Discord Bot (Gateway Mode)
DISCORD_BOT_TOKEN=your-bot-token-here
DISCORD_APP_ID=your-app-id-here

# Discord Bot (Webhook Mode) — use instead of gateway mode
# DISCORD_PUBLIC_KEY=your-ed25519-public-key-hex
# WEBHOOK_PORT=8080

# Encryption key for API key storage (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=your-64-hex-char-key-here

# Optional
# ADVISOR_CONFIG=/data/config.json
# KEY_STORE_PATH=/data/keys.json
